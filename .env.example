# Application
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
AI_SERVICE_URL=http://localhost:3002

# Database (PostgreSQL) - Use Neon or local
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=omnimind
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/omnimind

# Redis (Cloud - Redis Labs)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=your-qdrant-api-key-here

# AI / LLM (NVIDIA API - Required)
NVIDIA_API_KEY=your-nvidia-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7

# Storage
STORAGE_TYPE=local
S3_BUCKET=omnimind-files
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Authentication (Required - generate with: openssl rand -base64 32)
JWT_SECRET=CHANGE_THIS_TO_SECURE_RANDOM_STRING
JWT_EXPIRY=7d

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# File Upload
MAX_FILE_SIZE=104857600
UPLOAD_DIR=./storage/uploads
CLIPS_DIR=./storage/clips

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGIN=http://localhost:3000
