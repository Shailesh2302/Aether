NODE_ENV=production
PORT=3001

# Database (Neon / Postgres)
# POSTGRES_URL: pooled connection (used by the app at runtime)
# POSTGRES_DIRECT_URL: direct connection (used by `prisma migrate deploy`).
#   Required because Prisma's migration engine uses session features
#   (advisory locks, prepared statements) that Neon/PgBouncer's
#   transaction-mode pooler does not support. Get the direct URL from
#   the Neon dashboard by stripping `-pooler` from the hostname.
POSTGRES_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
POSTGRES_DIRECT_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/db?sslmode=require

# Redis (Redis Cloud)
REDIS_URL=redis://default:pass@host:port
REDIS_HOST=your-redis-host.cloud.redislabs.com
REDIS_PORT=12625
REDIS_PASSWORD=your-redis-password

# Qdrant Cloud
QDRANT_HOST=your-qdrant-host.aws.cloud.qdrant.io
QDRANT_PORT=6333
QDRANT_API_KEY=your-qdrant-api-key

# AI Service (Render)
AI_SERVICE_URL=https://aether-ai.onrender.com

# NVIDIA API (for AI service)
NVIDIA_API_KEY=nvapi-xxx

# JWT
JWT_SECRET=change-me-32-bytes-min
JWT_EXPIRY=7d

# Storage (cloudinary or local)
STORAGE_TYPE=cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_PRESET=aether

# CORS — must match your Vercel deployment URL
CORS_ORIGIN=https://aether-web.vercel.app

LOG_LEVEL=info
